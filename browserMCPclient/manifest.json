{
    "manifest_version": 3,
    "minimum_chrome_version": "116",
    "name": "browserMCP client",
    "version": "1.0.0",
    "description": "Client that connects to browserMCP server",
    "icons": {
        "128": "128.png"
    },
    "host_permissions": [
        "http://127.0.0.1:9000/*"
    ],
    "permissions": ["tabs", "tabGroups", "storage", "history"],
    "background": {
        "service_worker": "background.js",
        "scripts": ["background.js"]
    },
    "action": {
        "default_popup": "popup.html"
    }
}